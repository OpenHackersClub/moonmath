{
  "name": "moonmath-worker",
  "private": true,
  "version": "0.1.0",
  "description": "Cloudflare Worker shim for MoonMath. Serves prerendered SSG output via Static Assets and proxies the optional Lean4 compile fallback.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "typecheck": "tsc --noEmit",
    "tail": "wrangler tail"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250404.0",
    "typescript": "^5.4.5",
    "wrangler": "^3.114.0"
  }
}
